# Discord
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Hermes webhook — where the bot POSTs /create requests
HERMES_WEBHOOK_URL=http://gengar-claw-01.local:8644/webhook/gengar-dj-create
HERMES_WEBHOOK_SECRET=your_webhook_secret

# Bot API — internal callback endpoint for song creation responses
BOT_API_HOST=0.0.0.0
BOT_API_PORT=8080
BOT_CALLBACK_URL=http://gengar-dj-bot.gengar-lab.svc.cluster.local:8080

# Cloudflare R2 Credentials
R2_ACCOUNT_ID=your_cloudflare_account_id_here
R2_ACCESS_KEY_ID=your_r2_access_key_id_here
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here
R2_BUCKET_NAME=your_r2_bucket_name_here
R2_PUBLIC_URL=https://your-public-domain-or-r2-dev-url.com

# Song library path (local caching/fallbacks)
SONGS_DIR=/data/songs
PLAYLIST_FILE=/data/playlist.json

# Silence detection (seconds)
SILENCE_THRESHOLD=25
FADE_DURATION=3

# Logging
LOG_LEVEL=INFO
